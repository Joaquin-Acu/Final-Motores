# This .gitignore file is configured for Unity projects.
# Checked-in files will be tracked, and everything else will be ignored.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Mm]emoryCaptures/
/[尝]logs/
/[Logs]/

# Asset meta files must be tracked, but user-specific settings should be ignored
/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/Rider solution and project files
/*.csproj
/*.unityproj
/*.sln
/*.suo
/*.tmp
/*.user
/*.userprefs
/*.pidb
/*.booproj
/*.svd
/*.pdb
/*.opendb
/*.tlog

# Unity3D generated meta files
/*.pidb.meta
/*.pdb.meta
/*.mdb.meta

# Unity3D Generated File Groups
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
